# Copy this file to terraform.tfvars (gitignored) and fill in every
# placeholder below with your own real values — none of these are shared
# across deployments.

gcp_project = "your-gcp-project-id"
region      = "asia-southeast1"

# From your .env — the only value you need to fill in yourself.
sheet_id = "REPLACE_WITH_SHEET_ID"

gcs_bucket  = "your-gcs-bucket-name"
github_repo = "your-github-username/your-repo-name"

billing_account_id   = "XXXXXX-XXXXXX-XXXXXX"
alert_email          = "you@example.com"
budget_currency_code = "THB"
budget_amount_units  = "100"

allowed_group_id = ""       # filled in during Task 12
ocr_model        = "gemini" # verified free path; switch to "claude" once Anthropic billing is set up

# Phase gate — leave false for Phase 1 (core infra). After Phase 1.5
# (secret versions added + docker image pushed to Artifact Registry),
# flip to true and re-apply to create the two Cloud Run services.
deploy_services = false
